<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('../partials/head'); %>

    <style>
        .page-title {
            margin-bottom: 15px;
        }

        .load-btn {
            margin-bottom: 20px;
        }

        #statusMessage {
            margin-top: 10px;
            font-weight: bold;
        }

        #clubsSection {
            margin-top: 20px;
            display: none;
        }

        table th, table td {
            vertical-align: middle !important;
        }
    </style>
</head>
<body class="container">

    <header>
        <%- include('../partials/header'); %>
    </header>

    <main>
        <div class="jumbotron">
            <h1 class="page-title">University Club Directory</h1>
            <p>
                This page lists university clubs and their meeting details.
                Press the button below to load the club directory.
            </p>

            <button id="loadBtn" class="btn btn-primary load-btn">Load</button>

            <p id="statusMessage"></p>

            <div id="clubsSection">
                <table class="table table-bordered table-striped table-hover">
                    <thead class="thead-dark">
                        <tr>
                            <th>Club Name</th>
                            <th>Club President</th>
                            <th>Meeting Time</th>
                        </tr>
                    </thead>
                    <tbody id="clubsTableBody">
                    </tbody>
                </table>
            </div>
        </div>
    </main>

    <footer>
        <%- include('../partials/footer'); %>
    </footer>

    <script>
        const loadBtn = document.getElementById('loadBtn');
        const statusMessage = document.getElementById('statusMessage');
        const clubsSection = document.getElementById('clubsSection');
        const clubsTableBody = document.getElementById('clubsTableBody');

        loadBtn.addEventListener('click', async function () {
            statusMessage.textContent = 'Loading club directory...';
            clubsSection.style.display = 'none';
            clubsTableBody.innerHTML = '';

            try {
                const response = await fetch('https://2000031085.github.io/university-api/data.json');
                const data = await response.json();

                const clubs = data.university_data.clubs;

                if (!clubs || clubs.length === 0) {
                    statusMessage.textContent = 'No clubs were found.';
                    return;
                }

                clubs.forEach(function (club) {
                    const row = document.createElement('tr');

                    row.innerHTML = `
                        <td>${club.name}</td>
                        <td>${club.president}</td>
                        <td>${club.meeting_time}</td>
                    `;

                    clubsTableBody.appendChild(row);
                });

                clubsSection.style.display = 'block';
                statusMessage.textContent = 'Club directory loaded successfully.';
            } catch (error) {
                console.error('Error loading club data:', error);
                statusMessage.textContent = 'There was an error loading the club directory.';
            }
        });
    </script>

</body>
</html>